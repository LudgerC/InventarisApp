@model InventarisApp.Models.Info

@{
    ViewData["Title"] = "Add Device";
    var lokalen = ViewBag.Lokalen as List<InventarisApp.Models.Lokaal> ?? new List<InventarisApp.Models.Lokaal>();
    var locaties = ViewBag.Locaties as List<InventarisApp.Models.Locatie> ?? new List<InventarisApp.Models.Locatie>();
}

<div class="row min-vh-100 align-items-center justify-content-center bg-light">
    <div class="col-md-8 col-lg-6 py-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                <h3 class="mb-0 fw-bold">Nieuw Apparaat Toevoegen</h3>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h5 class="text-primary border-bottom pb-2 mb-3">Basis Informatie</h5>
                    <div class="row g-3">
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="type" class="form-control" placeholder="Type" />
                            <label asp-for="type" class="ms-2">Apparaat Type</label>
                            <span asp-validation-for="type" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="merk" class="form-control" placeholder="Merk" />
                            <label asp-for="merk" class="ms-2">Merk</label>
                            <span asp-validation-for="merk" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="model" class="form-control" placeholder="Model" />
                            <label asp-for="model" class="ms-2">Model</label>
                            <span asp-validation-for="model" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="serial_number" class="form-control" placeholder="Serienummer" />
                            <label asp-for="serial_number" class="ms-2">Serienummer</label>
                            <span asp-validation-for="serial_number" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="ip" class="form-control" placeholder="IP-adres" />
                            <label asp-for="ip" class="ms-2">IP-adres</label>
                            <span asp-validation-for="ip" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <select asp-for="status" class="form-select">
                                <option value="">-- Selecteer Status --</option>
                                <option value="Active">Actief</option>
                                <option value="Inactive">Inactief</option>
                                <option value="Maintenance">Onderhoud</option>
                            </select>
                            <label asp-for="status" class="ms-2">Status</label>
                            <span asp-validation-for="status" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="text-primary border-bottom pb-2 mt-4 mb-3">Locatie</h5>
                    <div class="row g-3">
                        <div class="col-md-6 form-floating mb-3">
                            <select id="campusSelection" class="form-select" onchange="filterRooms()">
                                <option value="">-- Selecteer Campus --</option>
                                @foreach (var loc in locaties)
                                {
                                    <option value="@loc.locatie_id">@loc.naam</option>
                                }
                            </select>
                            <label for="campusSelection" class="ms-2">Campus</label>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <select name="locationSelection" id="locationSelection" class="form-select" onchange="updateLocationValues()" disabled>
                                <option value="">-- Selecteer eerst een Campus --</option>
                            </select>
                            <label for="locationSelection" class="ms-2">Lokaal</label>
                            
                            <input type="hidden" asp-for="locatie_id" id="hiddenLocatieId" />
                            <input type="hidden" asp-for="lokaalnr" id="hiddenLokaalnr" />
                            <span asp-validation-for="lokaalnr" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <h5 class="text-primary border-bottom pb-2 mt-4 mb-3">Aankoop Informatie</h5>
                    <div class="row g-3">
                         <div class="col-md-6 form-floating mb-3">
                            <input asp-for="leverancier" class="form-control" placeholder="Leverancier" />
                            <label asp-for="leverancier" class="ms-2">Leverancier</label>
                            <span asp-validation-for="leverancier" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <select id="warrantyToggle" class="form-select" onchange="updateWarrantyFields()">
                                <option value="nee">Nee</option>
                                <option value="ja">Ja</option>
                            </select>
                            <label for="warrantyToggle" class="ms-2">Heeft het apparaat garantie?</label>
                        </div>
                        <div class="col-md-4 form-floating mb-3 warranty-field">
                            <input asp-for="garantie" id="garantieField" class="form-control" placeholder="Garantie" type="number" min="0" />
                            <label asp-for="garantie" class="ms-2">Garantie (Maanden)</label>
                            <span asp-validation-for="garantie" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 form-floating mb-3 warranty-field">
                            <input asp-for="aankoopdatum" id="aankoopdatumField" class="form-control" type="text" placeholder="dd/mm/jjjj" />
                            <label asp-for="aankoopdatum" class="ms-2">Aankoopdatum</label>
                            <span class="text-muted small ms-2">Formaat: dd/mm/jjjj</span>
                        </div>
                        <div class="col-md-4 form-floating mb-3 warranty-field">
                            <input asp-for="eind_garantie" id="eindGarantieField" class="form-control" type="text" placeholder="dd/mm/jjjj" />
                            <label asp-for="eind_garantie" class="ms-2">Einde Garantie</label>
                            <span class="text-muted small ms-2">Formaat: dd/mm/jjjj</span>
                        </div>
                    </div>

                    <h5 class="text-primary border-bottom pb-2 mt-4 mb-3">Optionele WiFi</h5>
                    <div class="row g-3">
                        <div class="col-md-6 form-floating mb-3">
                            <input name="mac_address" class="form-control" placeholder="MAC" />
                            <label for="mac_address" class="ms-2">MAC-adres</label>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input name="local_ip" class="form-control" placeholder="Lokaal IP" />
                            <label for="local_ip" class="ms-2">Lokaal IP-adres</label>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Annuleren</a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">Apparaat Opslaan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var allRooms = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(lokalen.Select(l => new { l.locatie_id, l.lokaalnr })));

        function filterRooms() {
            var campusId = document.getElementById("campusSelection").value;
            var roomSelect = document.getElementById("locationSelection");
            
            roomSelect.innerHTML = '<option value="">-- Selecteer Lokaal --</option>';
            
            if (campusId) {
                var filtered = allRooms.filter(r => r.locatie_id == campusId);
                filtered.forEach(function(r) {
                    var opt = document.createElement("option");
                    opt.value = r.locatie_id + "|" + r.lokaalnr;
                    opt.text = r.lokaalnr;
                    roomSelect.add(opt);
                });
                roomSelect.disabled = false;
            } else {
                roomSelect.disabled = true;
            }
            updateLocationValues();
        }

        function updateLocationValues() {
            var selected = document.getElementById("locationSelection").value;
            if (selected) {
                var parts = selected.split('|');
                document.getElementById("hiddenLocatieId").value = parts[0];
                document.getElementById("hiddenLokaalnr").value = parts[1];
            } else {
                document.getElementById("hiddenLocatieId").value = "";
                document.getElementById("hiddenLokaalnr").value = "";
            }
        }

        function updateWarrantyFields() {
            var hasWarranty = document.getElementById("warrantyToggle").value === "ja";
            var fields = ["garantieField", "aankoopdatumField", "eindGarantieField"];
            
            fields.forEach(function(fieldId) {
                var field = document.getElementById(fieldId);
                field.disabled = !hasWarranty;
                if (!hasWarranty) {
                    field.value = "";
                }
            });
        }

        // Initialize on page load
        document.addEventListener("DOMContentLoaded", function() {
            updateWarrantyFields();
        });
    </script>
}
