@model InventarisApp.Models.Info

<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

@{
    ViewData["Title"] = "Edit Device";
}

<div class="row min-vh-100 align-items-center justify-content-center bg-light">
    <div class="col-md-8 col-lg-6 py-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-secondary text-white text-center py-3 rounded-top-4">
                <h3 class="mb-0 fw-bold">Apparaat Bewerken - @Model.device_id</h3>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <!-- Read-only composite key -->
                    <input type="hidden" asp-for="type" />
                    <input type="hidden" asp-for="device_id" />
                    <input type="hidden" name="type" value="@Model.type" />
                    <input type="hidden" name="device_id" value="@Model.device_id" />
                    
                    <!-- Include other hidden props that shouldn't change -->
                    <input type="hidden" asp-for="merk" />
                    <input type="hidden" asp-for="serial_number" />

                    <div class="alert alert-info py-2 mb-4 shadow-sm border-0">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <i class="bi bi-tag me-2"></i>
                                <strong>Merk:</strong> @Model.merk <br/>
                                <i class="bi bi-hash me-2"></i>
                                <strong>Serienummer:</strong> @Model.serial_number
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mt-2 mt-md-0">
                                    <select asp-for="type" id="typeSelect" class="form-select" placeholder="Selecteer type...">
                                        @foreach (var type in ViewBag.DeviceTypes as List<string> ?? new List<string>())
                                        {
                                            <option value="@type" selected="@(Model.type == type ? "selected" : null)">@type</option>
                                        }
                                    </select>
                                    <label asp-for="type">Apparaat Type</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mb-3">Bewerkbare Gegevens</h5>
                    <div class="row g-3">
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="apparaatnaam" class="form-control" placeholder="Apparaatnaam" />
                            <label asp-for="apparaatnaam" class="ms-2">Apparaatnaam (Optioneel)</label>
                            <span asp-validation-for="apparaatnaam" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="model" class="form-control" placeholder="Model" />
                            <label asp-for="model" class="ms-2">Model</label>
                            <span asp-validation-for="model" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check form-switch pt-2">
                                <input class="form-check-input" type="checkbox" id="hasIpCheckbox" onchange="toggleIpField()" 
                                       checked="@(!string.IsNullOrEmpty(Model.ip))">
                                <label class="form-check-label ms-2" for="hasIpCheckbox">Heeft IP-adres?</label>
                            </div>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="ip" class="form-control" placeholder="IP-adres" id="ipField" 
                                   disabled="@(string.IsNullOrEmpty(Model.ip))" />
                            <label asp-for="ip" class="ms-2">IP-adres</label>
                            <span asp-validation-for="ip" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <select asp-for="status" class="form-select">
                                <option value="Active">Actief</option>
                                <option value="Inactive">Inactief</option>
                                <option value="Maintenance">Onderhoud</option>
                            </select>
                            <label asp-for="status" class="ms-2">Status</label>
                            <span asp-validation-for="status" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3">
                            <input asp-for="leverancier" class="form-control" placeholder="Leverancier" />
                            <label asp-for="leverancier" class="ms-2">Leverancier</label>
                            <span asp-validation-for="leverancier" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mt-4 mb-3">Garantie Informatie</h5>
                    <div class="row g-3">
                        <div class="col-md-6 form-floating mb-3">
                            <select id="warrantyToggle" class="form-select" onchange="updateWarrantyFields()">
                                @if (Model.garantie > 0 || Model.aankoopdatum.HasValue) {
                                    <option value="nee">Nee</option>
                                    <option value="ja" selected="selected">Ja</option>
                                } else {
                                    <option value="nee" selected="selected">Nee</option>
                                    <option value="ja">Ja</option>
                                }
                            </select>
                            <label for="warrantyToggle" class="ms-2">Heeft het apparaat garantie?</label>
                        </div>
                        <div class="col-md-6 form-floating mb-3 warranty-field">
                            <input asp-for="garantie" id="garantieField" class="form-control" placeholder="Garantie" type="number" min="0" />
                            <label asp-for="garantie" class="ms-2">Garantie (Maanden)</label>
                            <span asp-validation-for="garantie" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-floating mb-3 warranty-field">
                            <input asp-for="aankoopdatum" id="aankoopdatumField" class="form-control" type="text" placeholder="dd/mm/jjjj" />
                            <label asp-for="aankoopdatum" class="ms-2">Aankoopdatum</label>
                            <span class="text-muted small ms-2">Formaat: dd/mm/jjjj</span>
                        </div>
                        <div class="col-md-6 form-floating mb-3 warranty-field">
                            <input asp-for="eind_garantie" id="eindGarantieField" class="form-control" type="text" placeholder="dd/mm/jjjj" />
                            <label asp-for="eind_garantie" class="ms-2">Einde Garantie</label>
                            <span class="text-muted small ms-2">Formaat: dd/mm/jjjj</span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Annuleren</a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">Apparaat Bijwerken</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script>
        function updateWarrantyFields() {
            var hasWarranty = document.getElementById("warrantyToggle").value === "ja";
            var fields = ["garantieField", "aankoopdatumField", "eindGarantieField"];
            
            fields.forEach(function(fieldId) {
                var field = document.getElementById(fieldId);
                field.disabled = !hasWarranty;
            });
        }

        function handleWarrantyChange() {
             var hasWarranty = document.getElementById("warrantyToggle").value === "ja";
             var fields = ["garantieField", "aankoopdatumField", "eindGarantieField"];
             fields.forEach(function(fieldId) {
                var field = document.getElementById(fieldId);
                field.disabled = !hasWarranty;
                if (!hasWarranty) {
                    field.value = "";
                }
            });
        }

        function toggleIpField() {
            var hasIp = document.getElementById("hasIpCheckbox").checked;
            var ipField = document.getElementById("ipField");
            ipField.disabled = !hasIp;
            if (!hasIp) {
                ipField.value = "";
            }
        }

        // Initialize on page load
        document.addEventListener("DOMContentLoaded", function() {
            updateWarrantyFields();
            toggleIpField();
            // Attach specific handler for change to clear values
            document.getElementById("warrantyToggle").onchange = handleWarrantyChange;

            new TomSelect('#typeSelect', {
                create: false,
                sortField: { field: 'text', order: 'asc' }
            });
        });
    </script>
}
