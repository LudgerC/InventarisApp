@model IEnumerable<InventarisApp.Models.Info>

@{
    ViewData["Title"] = "Apparaten Overzicht";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-gradient" style="font-family: 'Outfit', sans-serif;">Apparaten Inventaris</h2>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="DeviceTypes" class="btn btn-outline-info shadow-sm">
                    <i class="bi bi-gear me-1"></i> Apparaattypes Beheren
                </a>
            }
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Nieuw Apparaat Toevoegen
            </a>
        </div>
    </div>

    <!-- Filters en Sorteren -->
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body bg-light rounded">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold"><i class="bi bi-search me-1"></i> Zoeken</label>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Merk, model, serienummer...">
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold"><i class="bi bi-pc-display me-1"></i> Type</label>
                    <select name="typeFilter" class="form-select">
                        <option value="">Alle types</option>
                        @if (ViewBag.Types != null)
                        {
                            foreach (var type in ViewBag.Types)
                            {
                                if (ViewData["CurrentType"]?.ToString() == type)
                                {
                                    <option value="@type" selected="selected">@type</option>
                                }
                                else
                                {
                                    <option value="@type">@type</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold"><i class="bi bi-activity me-1"></i> Status</label>
                    <select name="statusFilter" class="form-select">
                        <option value="">Alle statussen</option>
                        @if (ViewBag.Statuses != null)
                        {
                            foreach (string status in ViewBag.Statuses)
                            {
                                var statusLabel = status switch
                                {
                                    "Active" => "Actief",
                                    "Inactive" => "Inactief",
                                    "Maintenance" => "Onderhoud",
                                    _ => status
                                };
                                if (ViewData["CurrentStatus"]?.ToString() == status)
                                {
                                    <option value="@status" selected="selected">@statusLabel</option>
                                }
                                else
                                {
                                    <option value="@status">@statusLabel</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold"><i class="bi bi-sort-alpha-down me-1"></i> Sorteren</label>
                    <select name="sortOrder" class="form-select">
                        @{
                            var currentSort = ViewData["CurrentSort"]?.ToString();
                        }
                        @if (string.IsNullOrEmpty(currentSort))
                        {
                            <option value="" selected="selected">Type (A-Z)</option>
                        }
                        else
                        {
                            <option value="">Type (A-Z)</option>
                        }

                        @if (currentSort == "type_desc") { <option value="type_desc" selected="selected">Type (Z-A)</option> } else { <option value="type_desc">Type (Z-A)</option> }
                        @if (currentSort == "merk") { <option value="merk" selected="selected">Merk (A-Z)</option> } else { <option value="merk">Merk (A-Z)</option> }
                        @if (currentSort == "merk_desc") { <option value="merk_desc" selected="selected">Merk (Z-A)</option> } else { <option value="merk_desc">Merk (Z-A)</option> }
                        @if (currentSort == "id") { <option value="id" selected="selected">ID (Oplopend)</option> } else { <option value="id">ID (Oplopend)</option> }
                        @if (currentSort == "id_desc") { <option value="id_desc" selected="selected">ID (Aflopend)</option> } else { <option value="id_desc">ID (Aflopend)</option> }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-filter"></i> Toepassen
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Filters wissen">
                        <i class="bi bi-x-circle"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Type</th>
                    <th>ID</th>
                    <th>Merk</th>
                    <th>Naam</th>
                    <th>Serienummer</th>
                    <th>IP-adres</th>
                    <th>Status</th>
                    <th>Aankoopdatum</th>
                    <th>Garantie Tot</th>
                    <th class="text-center">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.type</td>
                        <td>@item.device_id</td>
                        <td>@item.merk</td>
                        <td class="fw-medium text-primary">@(string.IsNullOrEmpty(item.apparaatnaam) ? "-" : item.apparaatnaam)</td>
                        <td>@item.serial_number</td>
                        <td><code>@item.ip</code></td>
                        <td>
                            @{
                                var badgeClass = item.status switch
                                {
                                    "Active" => "bg-success text-white",
                                    "Inactive" => "bg-secondary text-white",
                                    "Maintenance" => "bg-warning text-dark",
                                    _ => "bg-light text-dark"
                                };
                                var statusLabel = item.status switch
                                {
                                    "Active" => "Actief",
                                    "Inactive" => "Inactief",
                                    "Maintenance" => "Onderhoud",
                                    _ => item.status
                                };
                            }
                            <span class="badge @badgeClass">
                                @statusLabel
                            </span>
                        </td>
                        <td>@(item.aankoopdatum?.ToString("dd/MM/yyyy") ?? "N.v.t.")</td>
                        <td>@(item.eind_garantie?.ToString("dd/MM/yyyy") ?? "N.v.t.")</td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-type="@item.type" asp-route-deviceId="@item.device_id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Bewerken
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger delete-btn" 
                                        data-action="@Url.Action("Delete", "Device", new { type = item.type, deviceId = item.device_id })"
                                        data-message="Weet je zeker dat je dit apparaat (@(item.apparaatnaam ?? item.merk)) wilt verwijderen?">
                                    <i class="bi bi-trash"></i> Verwijderen
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 bg-light text-muted">Geen apparaten gevonden in de inventaris.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Modals {
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill text-danger mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3">Bevestig Verwijdering</h5>
                <p id="deleteModalMessage" class="text-muted small">Weet je het zeker?</p>
                
                <form id="globalDeleteForm" method="post">
                    @Html.AntiForgeryToken()
                </form>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger px-4 shadow-sm">Verwijderen</button>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const deleteModalEl = document.getElementById('deleteConfirmModal');
            const deleteModal = new bootstrap.Modal(deleteModalEl);
            const deleteForm = document.getElementById('globalDeleteForm');
            const deleteMessage = document.getElementById('deleteModalMessage');
            const confirmBtn = document.getElementById('confirmDeleteBtn');

            document.querySelectorAll('.delete-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const action = this.getAttribute('data-action');
                    const message = this.getAttribute('data-message');
                    
                    deleteForm.setAttribute('action', action);
                    deleteMessage.textContent = message;
                    deleteModal.show();
                });
            });

            confirmBtn.addEventListener('click', function() {
                deleteForm.submit();
            });
        });
    </script>
}
