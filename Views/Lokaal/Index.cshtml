@model IEnumerable<InventarisApp.Models.Lokaal>

@{
    ViewData["Title"] = "Lokalen Beheren";
}

<div class="row min-vh-100 bg-light pt-4">
    <div class="col-md-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bold h2 mb-0"><i class="bi bi-door-open me-2 text-primary"></i>Lokalen</h1>
            <div class="d-flex gap-2">
                <a asp-controller="Locatie" asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-3">
                    <i class="bi bi-geo-alt me-2"></i>Campussen
                </a>
                <a asp-controller="MateriaalType" asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-3">
                    <i class="bi bi-tags me-2"></i>Materiaaltypes
                </a>
                <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                    <i class="bi bi-plus-lg me-2"></i>Nieuw Lokaal
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Naam</th>
                                <th>Campus</th>
                                <th class="text-center">Plaatsen</th>
                                <th class="text-center">Type</th>
                                <th class="text-end pe-4">Acties</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@item.Naam</div>
                                        <div class="text-muted small">@item.Beschrijving</div>
                                    </td>
                                    <td>@(item.IsExtern ? "-" : (string.IsNullOrEmpty(item.Locatie?.Afkorting) ? item.Locatie?.Naam ?? "Geen campus" : $"{item.Locatie.Afkorting} - {item.Locatie.Naam}"))</td>
                                    <td class="text-center">@item.AantalPlaatsen</td>
                                    <td class="text-center">
                                        @if (item.IsExtern)
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill">Extern</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark rounded-pill">Intern</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-light btn-sm rounded-pill px-3">Details</a>
                                            <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-outline-primary btn-sm rounded-pill"><i class="bi bi-pencil"></i></a>
                                            <form asp-action="Delete" asp-route-id="@item.ID" method="post" onsubmit="return confirm('Verwijder dit lokaal?');" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .transition {
        transition: all 0.3s ease;
    }
</style>
