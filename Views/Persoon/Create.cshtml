@model InventarisApp.Models.Persoon

@{
    ViewData["Title"] = "Nieuwe Persoon";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h3 class="fw-bold text-gradient" style="font-family: 'Outfit', sans-serif;">Nieuwe Persoon Toevoegen</h3>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Naam" class="form-label fw-bold">Voornaam</label>
                            <input asp-for="Naam" class="form-control" placeholder="Bijv. Jan" />
                            <span asp-validation-for="Naam" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Achternaam" class="form-label fw-bold">Achternaam</label>
                            <input asp-for="Achternaam" class="form-control" placeholder="Bijv. Peeters" />
                            <span asp-validation-for="Achternaam" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="functie" class="form-label fw-bold">Functie / Rol</label>
                            <input asp-for="functie" class="form-control" placeholder="Bijv. Docent, Student, Beheerder" />
                            <span asp-validation-for="functie" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="emailadres" class="form-label fw-bold">E-mailadres</label>
                            <input asp-for="emailadres" type="email" class="form-control" placeholder="jan.peeters@school.be" />
                            <span asp-validation-for="emailadres" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="tel" class="form-label fw-bold">Telefoonnummer</label>
                            <input asp-for="tel" type="tel" class="form-control" placeholder="04xx xx xx xx" />
                            <span asp-validation-for="tel" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-4">
                        <a asp-action="Index" class="btn btn-light px-4">Annuleren</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">
                            <i class="bi bi-save me-1"></i> Persoon Opslaan
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
