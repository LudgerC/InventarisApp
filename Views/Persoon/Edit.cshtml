@model InventarisApp.Models.Persoon

@{
    ViewData["Title"] = "Persoon Details & Bewerken";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- LINKER KANT: FORMULIER -->
        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h3 class="fw-bold text-gradient" style="font-family: 'Outfit', sans-serif;">
                        <i class="bi bi-person-gear me-2"></i>Persoon Bewerken
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="ID" />
                        
                        <div class="mb-3">
                            <label asp-for="Naam" class="form-label fw-bold">Voornaam</label>
                            <input asp-for="Naam" class="form-control bg-light" />
                            <span asp-validation-for="Naam" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Achternaam" class="form-label fw-bold">Achternaam</label>
                            <input asp-for="Achternaam" class="form-control bg-light" />
                            <span asp-validation-for="Achternaam" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="functie" class="form-label fw-bold">Functie</label>
                            <input asp-for="functie" class="form-control bg-light" />
                            <span asp-validation-for="functie" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="emailadres" class="form-label fw-bold">E-mailadres</label>
                            <input asp-for="emailadres" type="email" class="form-control bg-light" />
                            <span asp-validation-for="emailadres" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="tel" class="form-label fw-bold">Telefoonnummer</label>
                            <input asp-for="tel" type="tel" class="form-control bg-light" />
                            <span asp-validation-for="tel" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top mt-4 gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-3">Terug</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm w-100">
                                <i class="bi bi-save me-1"></i> Wijzigingen Opslaan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RECHTER KANT: LENINGEN TABEL -->
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h4 class="fw-bold text-secondary mb-0">
                        <i class="bi bi-clock-history me-2"></i>Uitleen Historiek
                    </h4>
                    <span class="badge bg-primary rounded-pill px-3 py-2">@(Model.Leningen?.Count ?? 0) Apparaat/Apparaten</span>
                </div>
                <div class="card-body p-4 p-md-4">
                    <p class="text-muted small mb-4">
                        Hieronder ziet u welke apparaten <strong>@Model.Naam</strong> momenteel in bezit heeft of in het verleden heeft geleend.
                        Informatie over deze leningen kan enkel in de Leningen-sectie worden aangepast.
                    </p>

                    <div class="table-responsive rounded border">
                        <table class="table table-hover table-striped align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Apparaat</th>
                                    <th>Startdatum</th>
                                    <th>Einddatum</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if(Model.Leningen != null && Model.Leningen.Any())
                                {
                                    @foreach(var lening in Model.Leningen.OrderByDescending(l => l.startdatum))
                                    {
                                        bool isAfgerond = lening.einddatum.HasValue && lening.einddatum.Value.Date <= DateTime.Now.Date;
                                        var infoName = lening.Device?.Infos?.FirstOrDefault()?.apparaatnaam ?? (lening.Device?.Infos?.FirstOrDefault()?.merk + " " + lening.Device?.Infos?.FirstOrDefault()?.model);
                                        var dispName = string.IsNullOrWhiteSpace(infoName) ? $"Type: {lening.Device?.type}" : infoName;

                                        <tr>
                                            <td>
                                                <div class="fw-bold">@dispName</div>
                                                <div class="text-muted small">#@lening.Device?.device_id (@lening.Device?.type)</div>
                                            </td>
                                            <td>@lening.startdatum.ToString("dd/MM/yyyy")</td>
                                            <td>@(lening.einddatum?.ToString("dd/MM/yyyy") ?? "-")</td>
                                            <td>
                                                @if(isAfgerond)
                                                {
                                                    <span class="badge bg-secondary text-white">Afgerond</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success text-white">Actief</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">Vandaar geen bekende lening-historie voor deze persoon.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
