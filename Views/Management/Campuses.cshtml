@model List<InventarisApp.Models.Locatie>
@{
    ViewData["Title"] = "Campussen Beheren";
}

<div class="row min-vh-100 bg-light pt-4">
    <div class="col-md-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bold h2"><i class="bi bi-building me-2 text-primary"></i>Campussen</h1>
            <button class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addCampusModal">
                <i class="bi bi-plus-lg me-2"></i>Nieuwe Campus
            </button>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Naam</th>
                                <th>Afkorting</th>
                                <th class="text-end pe-4">Acties</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var campus in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@campus.locatie_id</td>
                                    <td class="fw-bold">@campus.naam</td>
                                    <td><span class="badge bg-primary bg-opacity-10 text-primary px-3">@campus.abbreviation</span></td>
                                    <td class="text-end pe-4">
                                        <button type="button" class="btn btn-outline-danger btn-sm rounded-circle shadow-sm delete-btn" 
                                                data-action="@Url.Action("DeleteCampus", "Management", new { id = campus.locatie_id })"
                                                data-message="Weet je zeker dat je deze campus wilt verwijderen? Alle bijbehorende lokalen worden ook verwijderd en gekoppelde apparaten hebben dan geen locatie meer."
                                                title="Verwijderen">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="mt-4">
            <a asp-action="Index" class="btn btn-link text-muted p-0"><i class="bi bi-arrow-left me-2"></i>Terug naar Dashboard</a>
        </div>
    </div>
</div>

@section Modals {
    <!-- Add Campus Modal -->
    <div class="modal fade" id="addCampusModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Nieuwe Campus Toevoegen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreateCampus" method="post">
                    <div class="modal-body p-4">
                        <div class="form-floating mb-3">
                            <input name="naam" class="form-control" id="campusName" placeholder="Naam" required />
                            <label for="campusName">Campus Naam</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input name="abbreviation" class="form-control" id="campusAbbr" placeholder="Afkorting" required />
                            <label for="campusAbbr">Afkorting (bijv. GWS)</label>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuleren</button>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">Opslaan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill text-danger mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold mb-3">Bevestig Verwijdering</h5>
                    <p id="deleteModalMessage" class="text-muted small">Weet je het zeker?</p>
                    
                    <form id="globalDeleteForm" method="post">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-center">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Annuleren</button>
                    <button type="button" id="confirmDeleteBtn" class="btn btn-danger px-4 shadow-sm">Verwijderen</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const deleteModalEl = document.getElementById('deleteConfirmModal');
            const deleteModal = new bootstrap.Modal(deleteModalEl);
            const deleteForm = document.getElementById('globalDeleteForm');
            const deleteMessage = document.getElementById('deleteModalMessage');
            const confirmBtn = document.getElementById('confirmDeleteBtn');

            document.querySelectorAll('.delete-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const action = this.getAttribute('data-action');
                    const message = this.getAttribute('data-message');
                    
                    deleteForm.setAttribute('action', action);
                    deleteMessage.textContent = message;
                    deleteModal.show();
                });
            });

            confirmBtn.addEventListener('click', function() {
                deleteForm.submit();
            });
        });
    </script>
}
