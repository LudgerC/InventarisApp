@model List<InventarisApp.Models.Lokaal>
@{
    ViewData["Title"] = "Lokalen Beheren";
    var campuses = ViewBag.Campuses as List<InventarisApp.Models.Locatie> ?? new List<InventarisApp.Models.Locatie>();
}

<div class="row min-vh-100 bg-light pt-4">
    <div class="col-md-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bold h2"><i class="bi bi-door-open me-2 text-success"></i>Lokalen</h1>
            <button class="btn btn-success text-white shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addRoomModal">
                <i class="bi bi-plus-lg me-2"></i>Nieuw Lokaal
            </button>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Campus</th>
                                <th>Lokaalnr</th>
                                <th>Plaatsen</th>
                                <th class="text-end pe-4">Acties</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var room in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold">@room.Locatie?.naam</span>
                                        <small class="text-muted ms-1">(@room.Locatie?.abbreviation)</small>
                                    </td>
                                    <td class="fw-bold">@room.lokaalnr</td>
                                    <td>@room.plaatsen</td>
                                    <td class="text-end pe-4">
                                        <button type="button" class="btn btn-outline-danger btn-sm rounded-circle shadow-sm delete-btn" 
                                                data-action="@Url.Action("DeleteRoom", "Management", new { locatieId = room.locatie_id, lokaalnr = room.lokaalnr })"
                                                data-message="Weet je zeker dat je dit lokaal wilt verwijderen? Alle gekoppelde apparaten in dit lokaal hebben dan geen locatie meer."
                                                title="Verwijderen">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="mt-4">
            <a asp-action="Index" class="btn btn-link text-muted p-0"><i class="bi bi-arrow-left me-2"></i>Terug naar Dashboard</a>
        </div>
    </div>
</div>

@section Modals {
    <!-- Add Room Modal -->
    <div class="modal fade" id="addRoomModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Nieuw Lokaal Toevoegen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreateRoom" method="post">
                    <div class="modal-body p-4">
                        <div class="form-floating mb-3">
                            <select name="locatie_id" class="form-select" id="campusIdSelect" required>
                                <option value="">-- Selecteer Campus --</option>
                                @foreach (var campus in campuses)
                                {
                                    <option value="@campus.locatie_id">@campus.naam</option>
                                }
                            </select>
                            <label for="campusIdSelect">Campus</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input name="lokaalnr" class="form-control" id="roomNr" placeholder="Lokaalnr" required />
                            <label for="roomNr">Lokaal Nummer (bijv. A101)</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input name="plaatsen" type="number" class="form-control" id="places" placeholder="Plaatsen" value="30" required />
                            <label for="places">Aantal Plaatsen</label>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuleren</button>
                        <button type="submit" class="btn btn-success text-white px-4 shadow-sm">Opslaan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill text-danger mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold mb-3">Bevestig Verwijdering</h5>
                    <p id="deleteModalMessage" class="text-muted small">Weet je het zeker?</p>
                    
                    <form id="globalDeleteForm" method="post">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-center">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Annuleren</button>
                    <button type="button" id="confirmDeleteBtn" class="btn btn-danger px-4 shadow-sm">Verwijderen</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const deleteModalEl = document.getElementById('deleteConfirmModal');
            const deleteModal = new bootstrap.Modal(deleteModalEl);
            const deleteForm = document.getElementById('globalDeleteForm');
            const deleteMessage = document.getElementById('deleteModalMessage');
            const confirmBtn = document.getElementById('confirmDeleteBtn');

            document.querySelectorAll('.delete-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const action = this.getAttribute('data-action');
                    const message = this.getAttribute('data-message');
                    
                    deleteForm.setAttribute('action', action);
                    deleteMessage.textContent = message;
                    deleteModal.show();
                });
            });

            confirmBtn.addEventListener('click', function() {
                deleteForm.submit();
            });
        });
    </script>
}
